# ============================================================
# さくらレンタルサーバ 本番用 .env テンプレート
# サーバ上で「.env」としてコピーし、値を埋めてください（このファイルはコミット対象、.env は除外）
#   cp .env.production.example .env
#   php artisan key:generate   ← APP_KEY を自動生成
# ============================================================

APP_NAME="とおりすがりの和紅茶 POS"
APP_ENV=production
APP_KEY=                       # php artisan key:generate で生成（空のままにしない）
APP_DEBUG=false                # 本番は必ず false
APP_URL=https://XXXX.sakura.ne.jp   # ← あなたの初期ドメインに置換

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja_JP
APP_TIMEZONE=Asia/Tokyo

LOG_CHANNEL=stack
LOG_LEVEL=warning

# --- さくらの MySQL 接続情報（コントロールパネルの値に置換） ---
DB_CONNECTION=mysql
DB_HOST=mysqlXXXX.db.sakura.ne.jp   # ← データベースサーバ名
DB_PORT=3306
DB_DATABASE=XXXX_toorisugari        # ← データベース名
DB_USERNAME=XXXX                    # ← DBユーザー名
DB_PASSWORD=                        # ← DBパスワード（サーバ上の .env に直接記入）

# 共有ホスティングではキャッシュ/セッション/キューは file/database が無難
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

FILESYSTEM_DISK=public
